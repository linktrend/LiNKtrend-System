# Copy to .env and fill in locally. Never commit .env to git.
# After any credential was shared in chat, rotate keys in Supabase Dashboard.

# Supabase (LiNKtrend-AdminDB)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

# Direct Postgres (migrations / tooling). Prefer pooler in production.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Zulip (self-hosted app uses its own Postgres; these are for our gateway only)
ZULIP_SITE_URL=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
