# Copy to .env and fill in locally. Never commit .env to git.
# After any credential was shared in chat, rotate keys in Supabase Dashboard.

# Supabase (LiNKtrend-AdminDB)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

# Direct Postgres (migrations / tooling). Prefer Session pooler URI from Dashboard → Connect
# if db.<ref>.supabase.co fails with ENOTFOUND on IPv4-only networks.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Zulip (self-hosted app uses its own Postgres; these are for our gateway only)
ZULIP_SITE_URL=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
ZULIP_GATEWAY_PORT=8790
PRISM_HEARTBEAT_MS=60000
PRISM_RESIDUE_SWEEP=
PRISM_RESIDUE_BATCH=25

# Local mock that accepts bot-runtime POST (default port 8789)
OPENCLAW_SHIM_PORT=8789

# OpenClaw / LiNKbot-core handoff (optional). Default POST body = gateway `agent` params
# (message, idempotencyKey, linktrendGovernance, optional sessionKey). See README.
OPENCLAW_AGENT_RUN_URL=
OPENCLAW_RUN_AUTH_BEARER=
OPENCLAW_AGENT_RUN_BODY=agent_params
OPENCLAW_AGENT_INGRESS_MESSAGE=
OPENCLAW_AGENT_SESSION_KEY=
OPENCLAW_AGENT_ID=
BOT_RUNTIME_MISSION_ID=
BOT_RUNTIME_SKILL_NAME=bootstrap
